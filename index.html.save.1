<!-- ============================================================ -->
<!-- JAVASCRIPT                                                   -->
<!-- ============================================================ -->
<script>
  (function() {
    'use strict';

    // ===== CONFIG =====
    const FLASK_API = 'http://28.66.47.49:5002/send';

    // ===== PRODUCTS =====
    const PRODUCTS = [
      { id: 1, name: 'اسپرسو کلاسیک', desc: 'اصیل ایتالیایی', price: 45000, time: '۳', badge: '🔥', cat: 'coffee', emoji: '☕' },
      { id: 2, name: 'لاته ماکیاتو', desc: 'با کارامل', price: 58000, time: '۵', badge: '⭐', cat: 'coffee', emoji: '☕' },
      { id: 3, name: 'موکا شکلاتی', desc: 'شکلات تلخ', price: 62000, time: '۶', badge: '💚', cat: 'coffee', emoji: '🍫' },
      { id: 4, name: 'آیس لاته', desc: 'سرد با شیر بادام', price: 56000, time: '۴', badge: '🥤', cat: 'cold', emoji: '🧊' },
      { id: 5, name: 'اسموتی توت', desc: 'ماست یونانی', price: 49000, time: '۵', badge: '⭐', cat: 'cold', emoji: '🍓' },
      { id: 6, name: 'کیک شکلاتی', desc: 'با گاناش', price: 42000, time: '۷', badge: '🔥', cat: 'dessert', emoji: '🍰' },
      { id: 7, name: 'چیزکیک توت', desc: 'سس توت فرنگی', price: 53000, time: '۸', badge: '💚', cat: 'dessert', emoji: '🧀' },
      { id: 8, name: 'ساندویچ پنیر', desc: 'گودا و سبزیجات', price: 68000, time: '۱۰', badge: '🍕', cat: 'food', emoji: '🥪' },
      { id: 9, name: 'پیتزا مینی', desc: 'پپرونی و زیتون', price: 75000, time: '۱۲', badge: '🔥', cat: 'food', emoji: '🍕' },
      { id: 10, name: 'پاستا آلفردو', desc: 'مرغ و سس', price: 89000, time: '۱۵', badge: '⭐', cat: 'food', emoji: '🍝' }
    ];

    const BESTSELLERS = [PRODUCTS[0], PRODUCTS[5], PRODUCTS[8], PRODUCTS[1]];

    // ===== STATE =====
    let state = {
      table: null,
      cart: [],
      currentCat: 'all',
      timerInterval: null,
      orders: [] // ذخیره سفارشات
    };

    // ===== DOM =====
    const $ = s => document.querySelector(s);
    const $$ = s => document.querySelectorAll(s);

    // ===== HELPERS =====
    function fmt(n) { return n.toLocaleString('fa-IR'); }
    function getDate() { return new Intl.DateTimeFormat('fa-IR').format(new Date()); }
    function getTime() { return new Intl.DateTimeFormat('fa-IR', { hour: '2-digit', minute: '2-digit' }).format(new Date()); }
    function genOrder() { return '#' + String(Math.floor(100000 + Math.random() * 900000)); }

    // ===== ذرات طلایی =====
    function initParticles() {
      const canvas = document.getElementById('particles-canvas');
      const ctx = canvas.getContext('2d');
      let w, h;
      const particles = [];
      const COUNT = 60;

      function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      }
      window.addEventListener('resize', resize);
      resize();

      class Particle {
        constructor() { this.reset(); }
        reset() {
          this.x = Math.random() * w;
          this.y = Math.random() * h;
          this.size = Math.random() * 2 + 1.5;
          this.speedX = (Math.random() - 0.5) * 0.4;
          this.speedY = (Math.random() - 0.5) * 0.4;
          this.opacity = Math.random() * 0.5 + 0.2;
        }
        update() {
          this.x += this.speedX;
          this.y += this.speedY;
          if (this.x < 0 || this.x > w) { this.speedX *= -1; }
          if (this.y < 0 || this.y > h) { this.speedY *= -1; }
        }
        draw() {
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(212, 175, 55, ${this.opacity})`;
          ctx.fill();
          ctx.shadowColor = 'rgba(212, 175, 55, 0.2)';
          ctx.shadowBlur = 12;
        }
      }

      for (let i = 0; i < COUNT; i++) particles.push(new Particle());

      function animate() {
        ctx.clearRect(0, 0, w, h);
        particles.forEach(p => { p.update(); p.draw(); });
        requestAnimationFrame(animate);
      }
      animate();
    }

    // ===== مدیریت ذخیره‌سازی سفارشات =====
    function loadOrders() {
      try {
        const data = localStorage.getItem('cafe_orders');
        state.orders = data ? JSON.parse(data) : [];
      } catch { state.orders = []; }
    }

    function saveOrders() {
      try {
        localStorage.setItem('cafe_orders', JSON.stringify(state.orders));
      } catch (e) { console.warn('ذخیره سفارشات失敗', e); }
    }

    function addOrder(orderData) {
      state.orders.unshift(orderData); // جدیدترین در بالا
      if (state.orders.length > 100) state.orders.pop(); // محدودیت ۱۰۰ سفارش
      saveOrders();
    }

    function updateOrderStatus(orderId, status) {
      const order = state.orders.find(o => o.id === orderId);
      if (order) {
        order.status = status;
        saveOrders();
      }
    }

    // ===== افکت‌ها =====
    function createSparkles(target) {
      const rect = target.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const container = document.createElement('div');
      container.className = 'sparkle-container';
      document.body.appendChild(container);

      for (let i = 0; i < 16; i++) {
        const s = document.createElement('div');
        s.className = 'sparkle';
        const angle = Math.random() * Math.PI * 2;
        const dist = 60 + Math.random() * 100;
        s.style.cssText = `
          left:${cx}px; top:${cy}px;
          --tx:${Math.cos(angle) * dist}px;
          --ty:${Math.sin(angle) * dist}px;
          width:${4 + Math.random() * 8}px;
          height:${4 + Math.random() * 8}px;
          animation-duration:${0.6 + Math.random() * 0.4}s;
          background:${['#d4af37', '#f0d080', '#ffd700', '#f5e56b'][Math.floor(Math.random()*4)]};
        `;
        container.appendChild(s);
      }
      setTimeout(() => container.remove(), 1200);
    }

    function flyToCart(target) {
      const rect = target.getBoundingClientRect();
      const cart = document.getElementById('cart-float');
      const cartRect = cart.getBoundingClientRect();

      const flyer = document.createElement('div');
      flyer.className = 'fly-element';
      flyer.textContent = '✦';
      flyer.style.cssText = `
        left:${rect.left + rect.width/2 - 20}px;
        top:${rect.top}px;
        color:var(--gold);
        font-size:2.5rem;
        text-shadow:0 0 30px rgba(212,175,55,0.6);
      `;
      document.body.appendChild(flyer);

      requestAnimationFrame(() => {
        flyer.style.left = (cartRect.left + cartRect.width / 2 - 20) + 'px';
        flyer.style.top = (cartRect.top - 20) + 'px';
        flyer.style.transform = 'scale(0.3)';
        flyer.style.opacity = '0.6';
      });

      setTimeout(() => {
        flyer.remove();
        createSparkles(cart);
      }, 900);
    }

    // ===== رندر محصولات =====
    function renderProducts(cat, q) {
      let list = PRODUCTS;
      if (cat !== 'all') list = list.filter(p => p.cat === cat);
      if (q && q.trim()) {
        const s = q.trim().toLowerCase();
        list = list.filter(p => p.name.includes(s) || p.desc.includes(s));
      }
      if (!list.length) {
        $('#products').innerHTML = '<p style="grid-column:1/-1;text-align:center;opacity:0.3;padding:40px 0;">محصولی یافت نشد</p>';
        return;
      }
      $('#products').innerHTML = list.map(p => `
        <div class="product-card" data-id="${p.id}">
          <span class="emoji-big">${p.emoji}</span>
          ${p.badge ? `<span class="badge">${p.badge}</span>` : ''}
          <h4>${p.name}</h4>
          <div class="desc">${p.desc}</div>
          <div class="meta">
            <span class="price">${fmt(p.price)} تومان</span>
            <button class="add-btn" data-id="${p.id}"><i class="fas fa-plus"></i></button>
          </div>
        </div>
      `).join('');

      $('#products').querySelectorAll('.add-btn').forEach(btn => {
        btn.onclick = (e) => {
          e.stopPropagation();
          const id = +btn.dataset.id;
          const card = btn.closest('.product-card');
          addToCart(id);
          flyToCart(btn);
          createSparkles(card);
          card.style.transform = 'scale(1.06)';
          setTimeout(() => card.style.transform = '', 400);
        };
      });
    }

    // ===== رندر پرفروش‌ها =====
    function renderBestsellers() {
      const container = document.getElementById('bestseller-scroll');
      container.innerHTML = BESTSELLERS.map(p => `
        <div class="bs-item" data-id="${p.id}">
          <span class="emoji">${p.emoji}</span>
          <div class="name">${p.name}</div>
          <div class="price">${fmt(p.price)}</div>
        </div>
      `).join('');
      container.querySelectorAll('.bs-item').forEach(el => {
        el.addEventListener('click', () => {
          const id = +el.dataset.id;
          addToCart(id);
          createSparkles(el);
        });
      });
    }

    // ===== CART =====
    function addToCart(id) {
      const p = PRODUCTS.find(x => x.id === id);
      if (!p) return;
      const exist = state.cart.find(x => x.id === id);
      if (exist) exist.qty++;
      else state.cart.push({ ...p, qty: 1 });
      updateCartUI();
    }

    function removeFromCart(id) { state.cart = state.cart.filter(x => x.id !== id); updateCartUI(); }

    function changeQty(id, delta) {
      const item = state.cart.find(x => x.id === id);
      if (!item) return;
      item.qty += delta;
      if (item.qty <= 0) removeFromCart(id);
      else updateCartUI();
    }

    function getTotal() { return state.cart.reduce((s, i) => s + i.price * i.qty, 0); }
    function getCount() { return state.cart.reduce((s, i) => s + i.qty, 0); }

    function updateCartUI() {
      const count = getCount(), total = getTotal();
      $('#cart-badge').textContent = count;
      $('#cart-count').textContent = count;
      $('#cart-total').textContent = fmt(total);
      renderCartModal();
    }

    function renderCartModal() {
      if (!state.cart.length) {
        $('#cart-items').innerHTML = '<p style="text-align:center;opacity:0.4;padding:20px 0;">سبد خالی است</p>';
        $('#cart-modal-total').textContent = '۰';
        return;
      }
      $('#cart-items').innerHTML = state.cart.map(item => `
        <div class="checkout-item">
          <div><strong>${item.emoji} ${item.name}</strong> <span style="font-size:0.8rem;opacity:0.5;">${fmt(item.price)}</span></div>
          <div class="qty-control">
            <button data-id="${item.id}" data-delta="-1">-</button>
            <span>${item.qty}</span>
            <button data-id="${item.id}" data-delta="1">+</button>
            <button data-id="${item.id}" data-delta="0" style="background:transparent;color:#e74c3c;border:none;font-size:1rem;cursor:pointer;"><i class="fas fa-trash"></i></button>
          </div>
        </div>
      `).join('');
      $('#cart-items').querySelectorAll('.qty-control button').forEach(btn => {
        btn.onclick = () => {
          const id = +btn.dataset.id, delta = +btn.dataset.delta;
          if (delta === 0) removeFromCart(id);
          else changeQty(id, delta);
        };
      });
      $('#cart-modal-total').textContent = fmt(getTotal());
    }

    // ===== CHECKOUT =====
    function openCheckout() {
      if (!state.cart.length) { alert('سبد خالی است'); return; }
      if (!state.table) { alert('لطفاً شماره میز را وارد کنید'); return; }
      $('#checkout-table').textContent = state.table;
      $('#checkout-total').textContent = fmt(getTotal());
      $('#checkout-items').innerHTML = state.cart.map(item => `
        <div class="checkout-item">
          <div><strong>${item.emoji} ${item.name}</strong> <span style="opacity:0.5;">${fmt(item.price)}</span></div>
          <div class="qty-control">
            <button data-id="${item.id}" data-delta="-1">-</button>
            <span>${item.qty}</span>
            <button data-id="${item.id}" data-delta="1">+</button>
          </div>
        </div>
      `).join('');
      $('#checkout-items').querySelectorAll('.qty-control button').forEach(btn => {
        btn.onclick = () => {
          const id = +btn.dataset.id, delta = +btn.dataset.delta;
          changeQty(id, delta);
          openCheckout();
        };
      });
      $('#cart-modal').classList.remove('open');
      $('#checkout-modal').classList.add('open');
    }

    // ===== SEND TO BALE =====
    async function sendToBale(text) {
      try {
        const res = await fetch(FLASK_API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text })
        });
        const data = await res.json();
        return data.success === true;
      } catch { return false; }
    }

    // ===== TIMER =====
    function startTimer(durationMinutes = 15) {
      if (state.timerInterval) clearInterval(state.timerInterval);
      let totalSeconds = durationMinutes * 60;
      const display = document.getElementById('timer-display');
      const fill = document.getElementById('timer-fill');

      function update() {
        const mins = Math.floor(totalSeconds / 60);
        const secs = totalSeconds % 60;
        display.textContent = `${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}`;
        const pct = (totalSeconds / (durationMinutes * 60)) * 100;
        fill.style.width = pct + '%';
        if (totalSeconds <= 0) {
          clearInterval(state.timerInterval);
          display.textContent = '✅ آماده!';
          fill.style.background = '#27ae60';
        }
        totalSeconds--;
      }
      update();
      state.timerInterval = setInterval(update, 1000);
    }

    // ===== نمایش تاریخچه سفارشات =====
    function renderHistory() {
      const container = document.getElementById('history-list');
      if (!state.orders.length) {
        container.innerHTML = '<p style="text-align:center;opacity:0.4;padding:20px 0;">هیچ سفارشی ثبت نشده است</p>';
        return;
      }
      container.innerHTML = state.orders.map((order, index) => {
        const statusText = order.status === 'sent' ? 'ارسال شده' :
                          order.status === 'pending' ? 'در انتظار ارسال' :
                          order.status === 'failed' ? 'خطا در ارسال' : 'نامشخص';
        const statusClass = order.status === 'sent' ? 'sent' :
                           order.status === 'pending' ? 'pending' : 'failed';
        const itemsText = order.items.map(i => `${i.emoji} ${i.name} × ${i.qty}`).join('، ');
        return `
          <div class="saved-order">
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <div>
                <strong>${order.id}</strong>
                <span style="font-size:0.75rem;opacity:0.5;">${order.date} ${order.time}</span>
              </div>
              <span class="status ${statusClass}">${statusText}</span>
            </div>
            <div style="font-size:0.8rem;margin:4px 0;">میز: ${order.table} | ${itemsText}</div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px;">
              <span style="font-size:0.85rem;color:var(--gold-light);">${fmt(order.total)} تومان</span>
              ${order.status !== 'sent' ? `
                <button class="resend-btn" data-id="${order.id}">🔄 ارسال مجدد</button>
              ` : ''}
            </div>
          </div>
        `;
      }).join('');

      // رویداد ارسال مجدد
      container.querySelectorAll('.resend-btn').forEach(btn => {
        btn.onclick = async () => {
          const id = btn.dataset.id;
          const order = state.orders.find(o => o.id === id);
          if (!order) return;
          const ok = await sendToBale(order.message);
          if (ok) {
            updateOrderStatus(id, 'sent');
            btn.remove();
            alert('✅ سفارش مجدداً ارسال شد');
            renderHistory();
          } else {
            alert('❌ خطا در ارسال مجدد');
          }
        };
      });
    }

    // ===== SUBMIT ORDER =====
    async function submitOrder() {
      if (!state.cart.length) { alert('سبد خالی'); return; }
      if (!state.table) { alert('لطفاً شماره میز را وارد کنید'); return; }

      const table = state.table;
      const total = getTotal();
      const orderNum = genOrder();
      const options = Array.from(document.querySelectorAll('#checkout-modal .options-grid input:checked')).map(cb => cb.value);
      const notes = document.getElementById('order-notes').value.trim();
      const itemsText = state.cart.map(i =>
        `  • ${i.emoji} ${i.name} × ${i.qty} = ${fmt(i.price * i.qty)} تومان`
      ).join('\n');

      const msg = `📋 سفارش کافه‌لوکس\n─────────────────\n🔢 شماره: ${orderNum}\n🍽️ میز: ${table}\n📅 تاریخ: ${getDate()}\n⏰ ساعت: ${getTime()}\n─────────────────\n🛒 محصولات:\n${itemsText}\n─────────────────\n💰 جمع کل: ${fmt(total)} تومان\n─────────────────\n⚙️ تنظیمات: ${options.length ? options.join('، ') : 'ندارد'}\n📝 توضیحات: ${notes || 'ندارد'}`;

      // ذخیره سفارش (قبل از ارسال)
      const orderData = {
        id: orderNum,
        table: table,
        date: getDate(),
        time: getTime(),
        items: state.cart.map(i => ({ ...i })),
        total: total,
        options: options,
        notes: notes,
        message: msg,
        status: 'pending' // pending, sent, failed
      };
      addOrder(orderData);

      // ارسال به ربات
      const ok = await sendToBale(msg);
      if (ok) {
        updateOrderStatus(orderNum, 'sent');
      } else {
        updateOrderStatus(orderNum, 'failed');
        alert('⚠️ سفارش ذخیره شد اما ارسال به ربات انجام نشد. می‌توانید از بخش تاریخچه مجدداً ارسال کنید.');
      }

      // نمایش فاکتور
      $('#checkout-modal').classList.remove('open');
      document.getElementById('order-number').textContent = orderNum;
      document.getElementById('order-date').textContent = getDate();
      document.getElementById('order-time').textContent = getTime();
      document.getElementById('order-table').textContent = table;
      document.getElementById('order-amount').textContent = fmt(total);

      const itemsHtml = state.cart.map(i =>
        `<div class="item"><span>${i.emoji} ${i.name} × ${i.qty}</span><span>${fmt(i.price * i.qty)}</span></div>`
      ).join('');
      document.getElementById('invoice-items').innerHTML = itemsHtml;

      $('#success-modal').classList.add('open');
      startTimer(15);

      state.cart = [];
      updateCartUI();
      document.getElementById('order-notes').value = '';
      document.querySelectorAll('#checkout-modal .options-grid input').forEach(cb => cb.checked = false);
    }

    // ===== اشتراک‌گذاری و دانلود =====
    function shareInvoice() {
      const invoice = document.getElementById('invoice');
      const text = invoice.innerText;
      if (navigator.share) {
        navigator.share({ title: 'فاکتور کافه‌لوکس', text: text });
      } else {
        navigator.clipboard.writeText(text).then(() => alert('✅ متن فاکتور کپی شد!'));
      }
    }

    function downloadInvoice() {
      const invoice = document.getElementById('invoice');
      const text = invoice.innerText;
      const blob = new Blob([text], { type: 'text/plain' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `فاکتور_کافه_${getDate().replace(/\//g,'-')}.txt`;
      a.click();
    }

    // ===== WAITER / FEEDBACK =====
    async function requestWaiter() {
      if (!state.table) { alert('لطفاً شماره میز را وارد کنید'); return; }
      const msg = `🙋 درخواست گارسون\nمیز: ${state.table}\nساعت: ${getTime()}`;
      const ok = await sendToBale(msg);
      alert(ok ? `✅ درخواست گارسون برای میز ${state.table} ارسال شد` : '❌ خطا');
    }

    async function sendFeedback(name, text) {
      if (!state.table) { alert('لطفاً شماره میز را وارد کنید'); return; }
      const msg = `💬 انتقاد و پیشنهاد\nمیز: ${state.table}\nنام: ${name || 'ناشناس'}\nپیام: ${text}`;
      const ok = await sendToBale(msg);
      if (ok) { alert(`✅ نظر شما برای میز ${state.table} ثبت شد`); $('#feedback-modal').classList.remove('open'); }
      else alert('❌ خطا');
    }

    // ===== ورود شماره میز =====
    function showMainSite() {
      document.querySelectorAll('#hero, #bestsellers, #categories, #search-wrap, #products, #waiter-btn, #cart-float, #footer')
        .forEach(el => el.style.display = '');
      document.getElementById('header').style.display = '';
      document.getElementById('table-number').textContent = state.table;
      document.getElementById('login-page').classList.add('hide');

      // رندر محتوا
      renderProducts('all', '');
      renderBestsellers();
    }

    function handleLogin() {
      const input = document.getElementById('table-input');
      const val = input.value.trim();
      if (!val || isNaN(val) || parseInt(val) < 1) {
        document.getElementById('login-error').style.display = 'block';
        return;
      }
      document.getElementById('login-error').style.display = 'none';
      state.table = parseInt(val);
      showMainSite();

      // ذخیره در localStorage برای下次
      try { localStorage.setItem('cafe_table', state.table); } catch {}
    }

    // ===== INIT =====
    function init() {
      // ذرات
      initParticles();

      // بارگذاری سفارشات
      loadOrders();

      // بررسی شماره میز ذخیره شده
      try {
        const savedTable = localStorage.getItem('cafe_table');
        if (savedTable) {
          document.getElementById('table-input').value = savedTable;
        }
      } catch {}

      // رویداد ورود
      document.getElementById('login-btn').addEventListener('click', handleLogin);
      document.getElementById('table-input').addEventListener('keydown', (e) => {
        if (e.key === 'Enter') handleLogin();
      });

      // Splash
      setTimeout(() => {
        document.getElementById('splash').classList.add('hide');
      }, 2000);

      // تغییر شماره میز از هدر
      document.getElementById('table-badge').addEventListener('click', () => {
        if (confirm('آیا می‌خواهید شماره میز را تغییر دهید؟')) {
          document.querySelectorAll('#hero, #bestsellers, #categories, #search-wrap, #products, #waiter-btn, #cart-float, #footer')
            .forEach(el => el.style.display = 'none');
          document.getElementById('header').style.display = 'none';
          document.getElementById('login-page').classList.remove('hide');
          document.getElementById('table-input').value = '';
          document.getElementById('table-input').focus();
        }
      });

      // تاریخچه سفارشات
      document.getElementById('orders-history-btn').addEventListener('click', () => {
        renderHistory();
        document.getElementById('history-modal').classList.add('open');
      });
      document.querySelector('[data-close="history-modal"]').addEventListener('click', () => {
        document.getElementById('history-modal').classList.remove('open');
      });
      document.getElementById('history-modal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('history-modal')) {
          document.getElementById('history-modal').classList.remove('open');
        }
      });

      // سایر رویدادها
      document.getElementById('cart-open').onclick = () => { renderCartModal(); document.getElementById('cart-modal').classList.add('open'); };
      document.querySelector('[data-close="cart-modal"]').onclick = () => document.getElementById('cart-modal').classList.remove('open');
      document.getElementById('checkout-open').onclick = openCheckout;
      document.querySelector('[data-close="checkout-modal"]').onclick = () => document.getElementById('checkout-modal').classList.remove('open');
      document.getElementById('submit-order').onclick = submitOrder;

      document.getElementById('success-close').onclick = () => {
        document.getElementById('success-modal').classList.remove('open');
        if (state.timerInterval) clearInterval(state.timerInterval);
      };

      document.getElementById('waiter-btn').onclick = requestWaiter;

      document.getElementById('feedback-open').onclick = (e) => { e.preventDefault(); document.getElementById('feedback-modal').classList.add('open'); };
      document.querySelector('[data-close="feedback-modal"]').onclick = () => document.getElementById('feedback-modal').classList.remove('open');
      document.getElementById('feedback-form').onsubmit = (e) => {
        e.preventDefault();
        const name = document.getElementById('fb-name').value.trim();
        const msg = document.getElementById('fb-message').value.trim();
        if (!msg) { alert('لطفاً متن پیام را بنویسید'); return; }
        sendFeedback(name, msg);
        document.getElementById('fb-name').value = '';
        document.getElementById('fb-message').value = '';
      };

      document.getElementById('share-invoice').onclick = shareInvoice;
      document.getElementById('download-invoice').onclick = downloadInvoice;

      // جستجو و دسته‌بندی (بعد از رندر)
      document.getElementById('search-input').oninput = () =>
        renderProducts(state.currentCat, document.getElementById('search-input').value);

      document.querySelectorAll('.cat-btn').forEach(btn => {
        btn.onclick = () => {
          document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          state.currentCat = btn.dataset.cat;
          renderProducts(state.currentCat, document.getElementById('search-input').value);
        };
      });

      window.onscroll = () => document.getElementById('header').classList.toggle('shrink', window.scrollY > 60);

      console.log('✨ کافه‌لوکس نسخه نهایی با ورود میز و ذخیره سفارشات');
    }

    document.addEventListener('DOMContentLoaded', init);
  })();
</script>
</body>
</html>
