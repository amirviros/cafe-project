<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>کافه‌لوکس</title>
  <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family: 'Vazirmatn', sans-serif;
      background: #0c0705;
      color: #f0ece6;
      min-height: 100vh;
    }
    :root { --gold: #d4af37; --gold-light: #f0d080; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 10px; }

    /* SPLASH */
    #splash {
      position: fixed; inset: 0; z-index: 9999;
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      background: radial-gradient(circle at 30% 20%, #1f110b, #0c0705);
      transition: opacity 0.9s;
    }
    #splash.hide { opacity: 0; visibility: hidden; pointer-events: none; }
    .splash-icon { font-size: 4.5rem; color: var(--gold); animation: pulse 1.8s infinite; }
    .splash-title { font-size: 2.2rem; margin-top: 20px; color: var(--gold); }
    .splash-loader { margin-top: 30px; width: 40px; height: 40px; border: 3px solid rgba(212,175,55,0.15); border-top-color: var(--gold); border-radius: 50%; animation: spin 1s linear infinite; }
    @keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* HEADER */
    #header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      padding: 14px 24px;
      background: rgba(12,7,5,0.7); backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(212,175,55,0.15);
      display: flex; justify-content: space-between; align-items: center;
      transition: padding 0.3s;
    }
    #header.shrink { padding: 8px 20px; }
    .header-left { display: flex; align-items: center; gap: 12px; }
    .header-left i { font-size: 1.6rem; color: var(--gold); }
    .header-left span { font-weight: 600; font-size: 1.1rem; }
    .table-badge {
      background: var(--gold); color: #0c0705;
      padding: 4px 16px; border-radius: 40px;
      font-size: 0.8rem; font-weight: 700;
      display: flex; align-items: center; gap: 6px;
    }
    .header-right { display: flex; gap: 12px; }
    .icon-btn {
      background: rgba(255,255,255,0.06); border: none; color: #f0ece6;
      width: 42px; height: 42px; border-radius: 50%;
      font-size: 1.2rem; cursor: pointer;
      transition: 0.3s; position: relative;
      display: flex; align-items: center; justify-content: center;
    }
    .icon-btn:hover { background: var(--gold); color: #0c0705; }
    .cart-badge {
      position: absolute; top: -2px; right: -2px;
      background: #e74c3c; color: #fff; font-size: 0.6rem; font-weight: 700;
      width: 20px; height: 20px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }

    /* HERO */
    #hero {
      margin-top: 72px;
      padding: 40px 24px 60px;
      background: radial-gradient(ellipse at 60% 20%, #2d1a0f, #0c0705 70%);
      text-align: center;
    }
    .hero-img { max-width: 200px; margin: 0 auto 20px; border-radius: 50%; box-shadow: 0 20px 60px rgba(212,175,55,0.2); }
    .hero-img img { border-radius: 50%; width: 100%; aspect-ratio: 1/1; object-fit: cover; }
    .hero-title { font-size: 2.6rem; font-weight: 300; color: var(--gold); }
    .hero-btn { margin-top: 24px; display: inline-block; padding: 12px 40px; border: 1px solid var(--gold); color: var(--gold); border-radius: 60px; transition: 0.4s; cursor: pointer; background: transparent; }
    .hero-btn:hover { background: var(--gold); color: #0c0705; }

    /* CATEGORIES */
    #categories {
      padding: 10px 16px 20px;
      background: #0c0705;
      position: sticky; top: 68px; z-index: 100;
      display: flex; gap: 10px; overflow-x: auto;
      scrollbar-width: none;
    }
    #categories::-webkit-scrollbar { display: none; }
    .cat-btn {
      flex: 0 0 auto;
      padding: 8px 20px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 40px;
      color: #aaa;
      font-family: inherit;
      font-size: 0.85rem;
      cursor: pointer;
      transition: 0.3s;
      display: flex; align-items: center; gap: 6px;
      white-space: nowrap;
    }
    .cat-btn.active, .cat-btn:hover {
      background: var(--gold); color: #0c0705; border-color: var(--gold);
    }

    /* SEARCH */
    #search-wrap { padding: 0 20px 20px; background: #0c0705; }
    #search-wrap input {
      width: 100%; padding: 12px 20px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 60px;
      color: #f0ece6; font-family: inherit; font-size: 0.95rem;
    }
    #search-wrap input:focus { outline: none; border-color: var(--gold); }

    /* PRODUCTS */
    #products {
      padding: 10px 20px 140px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 20px;
    }
    .product-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.04);
      border-radius: 24px;
      padding: 14px 14px 18px;
      transition: 0.4s;
    }
    .product-card:hover { transform: translateY(-6px); border-color: var(--gold); }
    .product-card img {
      width: 100%; aspect-ratio: 1/1; object-fit: cover;
      border-radius: 16px; margin-bottom: 10px;
    }
    .product-card .badge {
      display: inline-block; font-size: 0.6rem; padding: 2px 10px; border-radius: 40px;
      background: var(--gold); color: #0c0705; font-weight: 700;
    }
    .product-card h4 { font-size: 1rem; margin-bottom: 2px; }
    .product-card .desc { font-size: 0.75rem; opacity: 0.5; }
    .product-card .meta { display: flex; justify-content: space-between; align-items: center; margin-top: 6px; }
    .product-card .price { font-weight: 700; color: var(--gold-light); }
    .product-card .add-btn {
      background: var(--gold); border: none; color: #0c0705;
      width: 34px; height: 34px; border-radius: 50%;
      font-size: 1rem; cursor: pointer;
      transition: 0.3s;
    }
    .product-card .add-btn:hover { transform: rotate(90deg) scale(1.1); }

    /* CART FLOATING */
    #cart-float {
      position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
      z-index: 500;
      background: rgba(12,7,5,0.85); backdrop-filter: blur(20px);
      border: 1px solid rgba(212,175,55,0.2);
      border-radius: 60px;
      padding: 10px 20px;
      display: flex; align-items: center; gap: 16px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.6);
    }
    #cart-float .info { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; }
    #cart-float .info span:first-child { background: var(--gold); color: #0c0705; padding: 0 10px; border-radius: 40px; font-weight: 700; }
    #cart-float .btn-cart { background: var(--gold); color: #0c0705; border: none; padding: 6px 18px; border-radius: 40px; font-weight: 700; cursor: pointer; font-family: inherit; }

    /* WAITER */
    #waiter-btn {
      position: fixed; bottom: 100px; left: 16px; z-index: 400;
      background: var(--gold); color: #0c0705; border: none;
      border-radius: 60px; padding: 10px 16px;
      box-shadow: 0 8px 30px rgba(212,175,55,0.25);
      font-weight: 700; display: flex; align-items: center; gap: 6px;
      cursor: pointer; font-family: inherit;
    }

    /* MODALS */
    .modal {
      position: fixed; inset: 0; z-index: 2000;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(10px);
      display: none; justify-content: center; align-items: center;
      padding: 20px;
    }
    .modal.open { display: flex; animation: fadeIn 0.3s; }
    .modal-content {
      max-width: 500px; width: 100%; max-height: 90vh; overflow-y: auto;
      background: rgba(20,12,8,0.9); backdrop-filter: blur(30px);
      border: 1px solid rgba(212,175,55,0.15);
      border-radius: 24px;
      padding: 28px 24px;
      box-shadow: 0 40px 80px rgba(0,0,0,0.7);
    }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.04); padding-bottom: 12px; }
    .modal-header h3 { font-size: 1.2rem; display: flex; align-items: center; gap: 8px; color: var(--gold); }
    .modal-close { background: none; border: none; font-size: 2rem; color: #888; cursor: pointer; }
    .modal-close:hover { color: #fff; }
    .checkout-item { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .qty-control { display: flex; align-items: center; gap: 8px; }
    .qty-control button { background: rgba(255,255,255,0.06); border: none; width: 28px; height: 28px; border-radius: 50%; color: #fff; font-size: 1rem; cursor: pointer; }
    .qty-control button:hover { background: var(--gold); color: #0c0705; }
    .options-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px,1fr)); gap: 6px 12px; margin: 12px 0; }
    .options-grid label { display: flex; align-items: center; gap: 6px; font-size: 0.85rem; color: #ccc; cursor: pointer; }
    #order-notes { width: 100%; padding: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; color: #fff; font-family: inherit; margin-top: 10px; }
    .btn-primary { width: 100%; padding: 14px; background: var(--gold); color: #0c0705; border: none; border-radius: 60px; font-weight: 700; font-size: 1rem; cursor: pointer; transition: 0.3s; font-family: inherit; margin-top: 16px; }
    .btn-primary:hover { transform: scale(1.02); }
    .success-icon { font-size: 4rem; color: #27ae60; text-align: center; }
    .order-details p { margin: 4px 0; font-size: 0.9rem; }

    /* FOOTER */
    #footer { background: #0c0705; padding: 30px 20px 16px; border-top: 1px solid rgba(212,175,55,0.1); text-align: center; font-size: 0.8rem; opacity: 0.5; }

    @media (max-width: 480px) {
      .header-left span { display: none; }
      #products { grid-template-columns: repeat(2, 1fr); gap: 14px; }
      .hero-title { font-size: 2rem; }
    }
    @keyframes fadeIn { from { opacity:0; transform:scale(0.95); } to { opacity:1; transform:scale(1); } }
  </style>
</head>
<body>

<div id="splash">
  <div class="splash-icon"><i class="fas fa-mug-hot"></i></div>
  <div class="splash-title">کافه‌لوکس</div>
  <div class="splash-loader"></div>
</div>

<header id="header">
  <div class="header-left"><i class="fas fa-mug-hot"></i><span>کافه‌لوکس</span></div>
  <div class="table-badge"><i class="fas fa-utensils"></i> میز <span id="table-number">--</span></div>
  <div class="header-right">
    <button class="icon-btn" id="cart-toggle"><i class="fas fa-shopping-bag"></i><span class="cart-badge" id="cart-badge">0</span></button>
    <button class="icon-btn" id="theme-toggle"><i class="fas fa-moon"></i></button>
  </div>
</header>

<section id="hero">
  <div class="hero-img"><img src="https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?w=400&auto=format" alt="قهوه" /></div>
  <h1 class="hero-title">هر فنجان، یک خاطره.</h1>
  <a href="#products" class="hero-btn">مشاهده منو</a>
</section>

<div id="categories">
  <button class="cat-btn active" data-cat="all"><i class="fas fa-th"></i> همه</button>
  <button class="cat-btn" data-cat="coffee"><i class="fas fa-mug-hot"></i> قهوه</button>
  <button class="cat-btn" data-cat="cold"><i class="fas fa-glass-whiskey"></i> سرد</button>
  <button class="cat-btn" data-cat="dessert"><i class="fas fa-cake"></i> دسر</button>
  <button class="cat-btn" data-cat="food"><i class="fas fa-pizza-slice"></i> غذا</button>
</div>

<div id="search-wrap"><input type="text" id="search-input" placeholder="جستجوی محصول..." /></div>
<div id="products"></div>

<button id="waiter-btn"><i class="fas fa-concierge-bell"></i> گارسون</button>

<div id="cart-float">
  <div class="info"><span id="cart-count">0</span> آیتم <span id="cart-total">۰</span> تومان</div>
  <button class="btn-cart" id="cart-open">مشاهده سبد</button>
</div>

<!-- MODALS -->
<div class="modal" id="cart-modal">
  <div class="modal-content">
    <div class="modal-header"><h3><i class="fas fa-shopping-bag"></i> سبد خرید</h3><button class="modal-close" data-close="cart-modal">&times;</button></div>
    <div id="cart-items"></div>
    <div style="display:flex;justify-content:space-between;margin-top:16px;font-weight:700;"><span>جمع کل:</span><span id="cart-modal-total">۰</span> تومان</div>
    <button class="btn-primary" id="checkout-open">ثبت سفارش</button>
  </div>
</div>

<div class="modal" id="checkout-modal">
  <div class="modal-content">
    <div class="modal-header"><h3><i class="fas fa-clipboard-list"></i> ثبت سفارش</h3><button class="modal-close" data-close="checkout-modal">&times;</button></div>
    <div id="checkout-items"></div>
    <div class="options-grid">
      <label><input type="checkbox" value="کم شکر" /> کم شکر</label>
      <label><input type="checkbox" value="پر شکر" /> پر شکر</label>
      <label><input type="checkbox" value="بدون یخ" /> بدون یخ</label>
      <label><input type="checkbox" value="خامه اضافه" /> خامه اضافه</label>
      <label><input type="checkbox" value="بدون خامه" /> بدون خامه</label>
      <label><input type="checkbox" value="شیر بادام" /> شیر بادام</label>
      <label><input type="checkbox" value="بدون لاکتوز" /> بدون لاکتوز</label>
      <label><input type="checkbox" value="لیوان بزرگ" /> لیوان بزرگ</label>
      <label><input type="checkbox" value="لیوان کوچک" /> لیوان کوچک</label>
    </div>
    <textarea id="order-notes" placeholder="توضیحات اضافی..."></textarea>
    <div style="display:flex;justify-content:space-between;margin:12px 0;"><span>میز: <span id="checkout-table">--</span></span><span>جمع: <span id="checkout-total">۰</span> تومان</span></div>
    <button class="btn-primary" id="submit-order">ثبت نهایی سفارش</button>
  </div>
</div>

<div class="modal" id="success-modal">
  <div class="modal-content" style="text-align:center;">
    <div class="success-icon"><i class="fas fa-check-circle"></i></div>
    <h3>✅ سفارش ثبت شد</h3>
    <div class="order-details">
      <p><strong>شماره:</strong> <span id="order-number">#123456</span></p>
      <p><strong>تاریخ:</strong> <span id="order-date"></span></p>
      <p><strong>ساعت:</strong> <span id="order-time"></span></p>
      <p><strong>میز:</strong> <span id="order-table">--</span></p>
      <p><strong>مبلغ:</strong> <span id="order-amount">۰</span> تومان</p>
      <p><strong>زمان آماده‌سازی:</strong> ۱۵ دقیقه</p>
    </div>
    <button class="btn-primary" id="success-close">باشه</button>
  </div>
</div>

<div class="modal" id="feedback-modal">
  <div class="modal-content">
    <div class="modal-header"><h3><i class="fas fa-comment-dots"></i> انتقاد و پیشنهاد</h3><button class="modal-close" data-close="feedback-modal">&times;</button></div>
    <form id="feedback-form">
      <input type="text" id="fb-name" placeholder="نام (اختیاری)" style="width:100%;padding:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:12px;color:#fff;margin-bottom:12px;" />
      <textarea id="fb-message" rows="4" placeholder="متن پیام..." required style="width:100%;padding:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:12px;color:#fff;resize:vertical;"></textarea>
      <button type="submit" class="btn-primary">ارسال</button>
    </form>
  </div>
</div>

<footer id="footer">
  <p style="margin-bottom:6px;">📞 ۰۲۱-۱۲۳۴۵۶۷۸ &nbsp;|&nbsp; 📍 تهران، ولیعصر</p>
  <p>همه روزه ۸ صبح تا ۱۲ شب</p>
  <div style="margin-top:12px;display:flex;justify-content:center;gap:20px;font-size:1.4rem;">
    <a href="#" style="color:#aaa;"><i class="fab fa-instagram"></i></a>
    <a href="#" style="color:#aaa;"><i class="fab fa-telegram"></i></a>
    <a href="#" style="color:#aaa;" id="feedback-open"><i class="fas fa-comment"></i></a>
  </div>
  <p style="margin-top:16px;opacity:0.3;font-size:0.7rem;">&copy; ۱۴۰۵ کافه‌لوکس</p>
</footer>

<script>
  (function() {
    const CONFIG = {
      FLASK_API: 'http://localhost:5000/send'  // این را بعداً با آی‌پی واقعی عوض کن
    };

    const PRODUCTS = [
      { id:1, name:'اسپرسو کلاسیک', desc:'اصیل ایتالیایی', price:45000, time:'۳', badge:'🔥', cat:'coffee', img:'https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?w=300&auto=format' },
      { id:2, name:'لاته ماکیاتو', desc:'با کارامل', price:58000, time:'۵', badge:'⭐', cat:'coffee', img:'https://images.unsplash.com/photo-1541167760496-1628856ab772?w=300&auto=format' },
      { id:3, name:'موکا شکلاتی', desc:'شکلات تلخ', price:62000, time:'۶', badge:'💚', cat:'coffee', img:'https://images.unsplash.com/photo-1559056199-641a0ac8b55e?w=300&auto=format' },
      { id:4, name:'آیس لاته', desc:'سرد با شیر بادام', price:56000, time:'۴', badge:'🥤', cat:'cold', img:'https://images.unsplash.com/photo-1461023058943-07fcbe16d735?w=300&auto=format' },
      { id:5, name:'اسموتی توت', desc:'ماست یونانی', price:49000, time:'۵', badge:'⭐', cat:'cold', img:'https://images.unsplash.com/photo-1553530666-ba11a7da3888?w=300&auto=format' },
      { id:6, name:'کیک شکلاتی', desc:'با گاناش', price:42000, time:'۷', badge:'🔥', cat:'dessert', img:'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=300&auto=format' },
      { id:7, name:'چیزکیک توت', desc:'سس توت فرنگی', price:53000, time:'۸', badge:'💚', cat:'dessert', img:'https://images.unsplash.com/photo-1524351199674-5c2c7c32b0fd?w=300&auto=format' },
      { id:8, name:'ساندویچ پنیر', desc:'گودا و سبزیجات', price:68000, time:'۱۰', badge:'🍕', cat:'food', img:'https://images.unsplash.com/photo-1528736235312-3dc1c4a4e741?w=300&auto=format' },
      { id:9, name:'پیتزا مینی', desc:'پپرونی و زیتون', price:75000, time:'۱۲', badge:'🔥', cat:'food', img:'https://images.unsplash.com/photo-1513104890138-7c749659a591?w=300&auto=format' },
      { id:10, name:'پاستا آلفردو', desc:'مرغ و سس', price:89000, time:'۱۵', badge:'⭐', cat:'food', img:'https://images.unsplash.com/photo-1645112411342-6889e477dbf4?w=300&auto=format' }
    ];

    let state = { cart: [], currentCat: 'all', table: null };

    const $ = s => document.querySelector(s);
    const $$ = s => document.querySelectorAll(s);

    function fmt(n) { return n.toLocaleString('fa-IR'); }
    function getTable() { return new URLSearchParams(location.search).get('table') || null; }
    function getDate() { return new Intl.DateTimeFormat('fa-IR').format(new Date()); }
    function getTime() { return new Intl.DateTimeFormat('fa-IR', {hour:'2-digit',minute:'2-digit'}).format(new Date()); }
    function genOrder() { return '#' + String(Math.floor(100000+Math.random()*900000)); }

    function renderProducts(cat, q) {
      let list = PRODUCTS;
      if (cat !== 'all') list = list.filter(p => p.cat === cat);
      if (q && q.trim()) { const s = q.trim().toLowerCase(); list = list.filter(p => p.name.includes(s) || p.desc.includes(s)); }
      if (!list.length) { $('#products').innerHTML = '<p style="grid-column:1/-1;text-align:center;opacity:0.3;padding:40px 0;">محصولی یافت نشد</p>'; return; }
      $('#products').innerHTML = list.map(p => `
        <div class="product-card">
          <img src="${p.img}" alt="${p.name}" loading="lazy" />
          ${p.badge ? `<span class="badge">${p.badge}</span>` : ''}
          <h4>${p.name}</h4>
          <div class="desc">${p.desc}</div>
          <div class="meta">
            <span class="price">${fmt(p.price)} تومان</span>
            <button class="add-btn" data-id="${p.id}"><i class="fas fa-plus"></i></button>
          </div>
        </div>
      `).join('');
      $('#products').querySelectorAll('.add-btn').forEach(btn => {
        btn.onclick = () => {
          const id = +btn.dataset.id;
          addToCart(id);
          btn.closest('.product-card').style.transform = 'scale(1.04)';
          setTimeout(() => btn.closest('.product-card').style.transform = '', 300);
        };
      });
    }

    function addToCart(id) {
      const p = PRODUCTS.find(x => x.id === id);
      if (!p) return;
      const exist = state.cart.find(x => x.id === id);
      if (exist) exist.qty++;
      else state.cart.push({ ...p, qty: 1 });
      updateCartUI();
    }

    function removeFromCart(id) { state.cart = state.cart.filter(x => x.id !== id); updateCartUI(); }
    function changeQty(id, delta) {
      const item = state.cart.find(x => x.id === id);
      if (!item) return;
      item.qty += delta;
      if (item.qty <= 0) removeFromCart(id);
      else updateCartUI();
    }
    function getTotal() { return state.cart.reduce((s, i) => s + i.price * i.qty, 0); }
    function getCount() { return state.cart.reduce((s, i) => s + i.qty, 0); }

    function updateCartUI() {
      const count = getCount(), total = getTotal();
      $('#cart-badge').textContent = count;
      $('#cart-count').textContent = count;
      $('#cart-total').textContent = fmt(total);
      renderCartModal();
    }

    function renderCartModal() {
      if (!state.cart.length) {
        $('#cart-items').innerHTML = '<p style="text-align:center;opacity:0.4;padding:20px 0;">سبد خالی است</p>';
        $('#cart-modal-total').textContent = '۰';
        return;
      }
      $('#cart-items').innerHTML = state.cart.map(item => `
        <div class="checkout-item">
          <div><strong>${item.name}</strong> <span style="font-size:0.8rem;opacity:0.5;">${fmt(item.price)}</span></div>
          <div class="qty-control">
            <button data-id="${item.id}" data-delta="-1">-</button>
            <span>${item.qty}</span>
            <button data-id="${item.id}" data-delta="1">+</button>
            <button data-id="${item.id}" data-delta="0" style="background:transparent;color:#e74c3c;border:none;font-size:1rem;cursor:pointer;"><i class="fas fa-trash"></i></button>
          </div>
        </div>
      `).join('');
      $('#cart-items').querySelectorAll('.qty-control button').forEach(btn => {
        btn.onclick = () => {
          const id = +btn.dataset.id, delta = +btn.dataset.delta;
          if (delta === 0) removeFromCart(id);
          else changeQty(id, delta);
        };
      });
      $('#cart-modal-total').textContent = fmt(getTotal());
    }

    function openCheckout() {
      if (!state.cart.length) { alert('سبد خالی است'); return; }
      $('#checkout-table').textContent = state.table || '--';
      $('#checkout-total').textContent = fmt(getTotal());
      $('#checkout-items').innerHTML = state.cart.map(item => `
        <div class="checkout-item">
          <div><strong>${item.name}</strong> <span style="opacity:0.5;">${fmt(item.price)}</span></div>
          <div class="qty-control">
            <button data-id="${item.id}" data-delta="-1">-</button>
            <span>${item.qty}</span>
            <button data-id="${item.id}" data-delta="1">+</button>
          </div>
        </div>
      `).join('');
      $('#checkout-items').querySelectorAll('.qty-control button').forEach(btn => {
        btn.onclick = () => {
          const id = +btn.dataset.id, delta = +btn.dataset.delta;
          changeQty(id, delta);
          openCheckout();
        };
      });
      $('#cart-modal').classList.remove('open');
      $('#checkout-modal').classList.add('open');
    }

    async function sendToBale(text) {
      try {
        const res = await fetch(CONFIG.FLASK_API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text })
        });
        const data = await res.json();
        return data.success === true;
      } catch { return false; }
    }

    async function submitOrder() {
      if (!state.cart.length) { alert('سبد خالی'); return; }
      const table = state.table || 'نامشخص', total = getTotal(), orderNum = genOrder();
      const options = Array.from(document.querySelectorAll('#checkout-modal .options-grid input:checked')).map(cb => cb.value);
      const notes = document.getElementById('order-notes').value.trim();
      const itemsText = state.cart.map(i => `  • ${i.name} × ${i.qty} = ${fmt(i.price*i.qty)} تومان`).join('\n');
      const msg = `📋 سفارش کافه‌لوکس\n─────────────────\n🔢 شماره: ${orderNum}\n🍽️ میز: ${table}\n📅 تاریخ: ${getDate()}\n⏰ ساعت: ${getTime()}\n─────────────────\n🛒 محصولات:\n${itemsText}\n─────────────────\n💰 جمع کل: ${fmt(total)} تومان\n─────────────────\n⚙️ تنظیمات: ${options.length ? options.join('، ') : 'ندارد'}\n📝 توضیحات: ${notes || 'ندارد'}`;
      const ok = await sendToBale(msg);
      if (!ok) { alert('❌ خطا در ارسال سفارش'); return; }
      $('#checkout-modal').classList.remove('open');
      document.getElementById('order-number').textContent = orderNum;
      document.getElementById('order-date').textContent = getDate();
      document.getElementById('order-time').textContent = getTime();
      document.getElementById('order-table').textContent = table;
      document.getElementById('order-amount').textContent = fmt(total);
      $('#success-modal').classList.add('open');
      state.cart = [];
      updateCartUI();
      document.getElementById('order-notes').value = '';
      document.querySelectorAll('#checkout-modal .options-grid input').forEach(cb => cb.checked = false);
    }

    async function requestWaiter() {
      const table = state.table || 'نامشخص';
      const msg = `🙋 درخواست گارسون\nمیز: ${table}\nساعت: ${getTime()}`;
      const ok = await sendToBale(msg);
      alert(ok ? '✅ درخواست ارسال شد' : '❌ خطا');
    }

    async function sendFeedback(name, text) {
      const table = state.table || 'نامشخص';
      const msg = `💬 انتقاد و پیشنهاد\nمیز: ${table}\nنام: ${name || 'ناشناس'}\nپیام: ${text}`;
      const ok = await sendToBale(msg);
      if (ok) { alert('✅ نظر شما ثبت شد'); $('#feedback-modal').classList.remove('open'); }
      else alert('❌ خطا');
    }

    function init() {
      state.table = getTable();
      document.getElementById('table-number').textContent = state.table || '--';
      setTimeout(() => { document.getElementById('splash').classList.add('hide'); renderProducts('all', ''); }, 2000);
      document.getElementById('search-input').oninput = () => renderProducts(state.currentCat, document.getElementById('search-input').value);
      document.querySelectorAll('.cat-btn').forEach(btn => {
        btn.onclick = () => {
          document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          state.currentCat = btn.dataset.cat;
          renderProducts(state.currentCat, document.getElementById('search-input').value);
        };
      });
      document.getElementById('cart-open').onclick = () => { renderCartModal(); document.getElementById('cart-modal').classList.add('open'); };
      document.querySelector('[data-close="cart-modal"]').onclick = () => document.getElementById('cart-modal').classList.remove('open');
      document.getElementById('checkout-open').onclick = openCheckout;
      document.querySelector('[data-close="checkout-modal"]').onclick = () => document.getElementById('checkout-modal').classList.remove('open');
      document.getElementById('submit-order').onclick = submitOrder;
      document.getElementById('success-close').onclick = () => document.getElementById('success-modal').classList.remove('open');
      document.getElementById('waiter-btn').onclick = requestWaiter;
      document.getElementById('feedback-open').onclick = (e) => { e.preventDefault(); document.getElementById('feedback-modal').classList.add('open'); };
      document.querySelector('[data-close="feedback-modal"]').onclick = () => document.getElementById('feedback-modal').classList.remove('open');
      document.getElementById('feedback-form').onsubmit = (e) => {
        e.preventDefault();
        const name = document.getElementById('fb-name').value.trim();
        const msg = document.getElementById('fb-message').value.trim();
        if (!msg) { alert('لطفاً متن پیام را بنویسید'); return; }
        sendFeedback(name, msg);
        document.getElementById('fb-name').value = '';
        document.getElementById('fb-message').value = '';
      };
      document.getElementById('theme-toggle').onclick = () => {
        document.body.style.background = document.body.style.background === 'rgb(12, 7, 5)' ? '#f5efe8' : '#0c0705';
        document.body.style.color = document.body.style.color === 'rgb(240, 236, 230)' ? '#1a0e0b' : '#f0ece6';
      };
      window.onscroll = () => document.getElementById('header').classList.toggle('shrink', window.scrollY > 60);
    }
    document.addEventListener('DOMContentLoaded', init);
  })();
</script>
</body>
</html>
